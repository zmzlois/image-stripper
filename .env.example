OPENAI_API_KEY=
GEMINI_API_KEY=

# Polar payment flow. Use sandbox until production checkout is verified.
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
