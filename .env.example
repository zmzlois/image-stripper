OPENAI_API_KEY=
GEMINI_API_KEY=

# Password accounts. Owner email can sign in without a password.
AUTH_SESSION_SECRET=
# Example: {"user@example.com":"scrypt:salt:hexhash"}
AUTH_USERS_JSON={}

# Polar payment flow. Use sandbox until production checkout is verified.
POLAR_SERVER=production
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=

# Backwards-compatible fallback if a specific plan product id is missing.
POLAR_PRODUCT_ID=
POLAR_STARTER_PRODUCT_ID=
POLAR_PRO_PRODUCT_ID=
POLAR_STUDIO_PRODUCT_ID=
POLAR_MONTHLY_PRODUCT_ID=
POLAR_LIFETIME_PRODUCT_ID=
POLAR_CREDIT_METER_ID=
POLAR_LIFETIME_BENEFIT_ID=
POLAR_USAGE_EVENT_NAME=image_generation
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to false only for local AI-generation testing without payment.
PAYMENT_REQUIRED=true

# Local Docker Postgres:
# docker compose up -d postgres
POSTGRES_URL=postgres://image_stripper:image_stripper@localhost:5432/image_stripper

# Vercel Blob:
BLOB_READ_WRITE_TOKEN=
# Match the access mode of the connected Blob store: public or private.
VERCEL_BLOB_ACCESS=private
